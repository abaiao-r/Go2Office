@startuml hour-tracking
!theme plain
skinparam backgroundColor #FEFEFE
title Daily Work Hours Calculation (First Entry / Last Exit)

start

:Collect all sessions for the day;
note right
  Session 1: 6:00 AM - 6:30 AM
  Session 2: 9:00 AM - 5:00 PM
end note

:Find First Entry (earliest);
:Find Last Exit (latest or 7PM if none);
note right
  First Entry = 6:00 AM
  Last Exit = 5:00 PM
end note

if (Both entry & exit before 7AM?) then (yes)
  :Return 0h (counts as day);
  stop
else (no)
endif

if (First Entry < 7AM?) then (yes)
  :Clamp to 7:00 AM;
else (no)
  if (First Entry > 7PM?) then (yes)
    :Clamp to 7:00 PM;
  endif
endif

if (Last Exit > 7PM?) then (yes)
  :Clamp to 7:00 PM;
else (no)
  if (Last Exit < 7AM?) then (yes)
    :Clamp to 7:00 AM;
  endif
endif

:Calculate: Last Exit - First Entry;
note right
  7AM to 5PM = 10 hours
end note

if (duration > 10h?) then (yes)
  :Cap at 10 hours;
  :Mark as capped;
endif

:Return worked hours;
note right
  hours = 10.0 (capped)
end note

stop
@enduml
